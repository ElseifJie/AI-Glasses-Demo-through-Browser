PORT=8787
WEB_ORIGIN=http://localhost:5173
VEADK_AGENT_URL=http://127.0.0.1:9001
ARKCLAW_ROUTED_INTENTS=send_feishu_message
IDLE_TIMEOUT_MS=10000
SESSION_KEY=main

# ===== 提示词配置 =====
# 支持占位符: {current_date} {current_time} {current_weekday} {user_profile}
# 闲聊系统提示词（角色+用户画像+时间+回复格式）
AGENT_PROMPT_CHAT='你是 AI 眼镜助手，一位知识渊博、亲切自然的生活小助理。你可以陪用户聊天、回答问题，也能通过联网搜索获取最新信息。回复风格自然、简洁、有温度，像朋友对话一样。

关于用户: {user_profile}'
# 联网搜索系统提示词
AGENT_PROMPT_SEARCH='你是 AI 眼镜助手，具备联网搜索能力。请根据搜索结果给出准确、简洁、自然的中文答复。'
# 拍照图片识别系统提示词
AGENT_PROMPT_VISION='你是 AI 眼镜助手，负责理解用户刚拍摄的图片。用一句简短的话描述画面中最重要的内容（适合语音播报），再用 2-3 句话补充细节。'
# 用户画像提取提示词（占位符: {profile_json} {user_input}）
AGENT_PROMPT_PROFILE='你需要根据用户输入，提取并更新用户个人信息。

当前画像（JSON）：
{profile_json}

最新用户输入：{user_input}

请从用户输入中提取所有与用户个人相关的信息，以 JSON key-value 形式输出。
字段名可以自由定义，示例：name、age、occupation、location、hobbies、favorite_food、pet、family、recent_event 等。没有固定字段限制。

规则：
1. 仅当用户明确提及才提取，不要推测
2. 新信息与旧信息不冲突时，合并保留
3. 新信息与旧信息冲突时，以新信息为准
4. 特殊字段 memories：列表，存储用户提到的关键事件，去重后保留最近 20 条
5. 其他字段：字符串或数字，如用户未提及则保留原值或省略

输出 JSON（不要输出其他内容）：
{"memories": [...], "任意字段名": "值", ...}'
# 回复格式要求（共用，占位符: {current_date} {current_time} {current_weekday}）
AGENT_REPLY_FORMAT='当前时间: {current_date} 周{current_weekday} {current_time}。
回复要求: 适合语音播报的简短句子开头（用于 TTS），再用 1-3 句补充完整信息。全文控制在 150 字以内。'

# ===== ArkClaw 网关 =====
GATEWAY_URL=
GATEWAY_INSTANCE=
GATEWAY_APIKEY=
GATEWAY_TOKEN=

# ===== LLM 模型配置 =====
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
OPENAI_API_KEY=
# 通用闲聊、联网搜索结果总结
AGENT_CHAT_MODEL=doubao-1-5-lite-32k-250115
# 拍照图片识别
AGENT_VISION_MODEL=doubao-seed-2-0-mini-260428

# ===== 火山引擎 ASR（语音识别）=====
VOLC_ASR_APP_KEY=
VOLC_ASR_ACCESS_KEY=
VOLC_ASR_RESOURCE_ID=
VOLC_ASR_URL=

# ===== 火山引擎 TTS（语音合成）=====
VOLC_TTS_APP_ID=
VOLC_TTS_ACCESS_TOKEN=
VOLC_TTS_RESOURCE_ID=
VOLC_TTS_VOICE_TYPE=
VOLC_TTS_URL=

# ===== 火山引擎联网搜索 =====
TOOL_WEB_SEARCH_ACCESS_KEY=
HOST=127.0.0.1
PORT=8787
VEADK_AGENT_URL=http://127.0.0.1:9001
WEB_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
VITE_GATEWAY_WS_URL=ws://127.0.0.1:8787

# ===== ArkClaw 网关 =====
GATEWAY_URL=
GATEWAY_INSTANCE=
GATEWAY_APIKEY=
GATEWAY_TOKEN=
# ArkClaw 聊天安全超时（毫秒），默认 1800000（30 分钟）。
# 正常情况下 ArkClaw 处理多久就等多久；此超时仅在 WebSocket 异常无法感知断连时兜底。
ARKCLAW_CHAT_TIMEOUT_MS=1800000

# ===== LLM 模型配置 =====
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
OPENAI_API_KEY=
# 通用闲聊、联网搜索结果总结
AGENT_CHAT_MODEL=doubao-1-5-lite-32k-250115
# 拍照图片识别
AGENT_VISION_MODEL=doubao-seed-2-0-mini-260428

# ===== 火山引擎 ASR（语音识别）=====
VOLC_ASR_APP_KEY=
VOLC_ASR_ACCESS_KEY=
VOLC_ASR_RESOURCE_ID=
VOLC_ASR_URL=

# ===== 火山引擎 TTS（语音合成）=====
VOLC_TTS_APP_ID=
VOLC_TTS_ACCESS_TOKEN=
VOLC_TTS_RESOURCE_ID=
VOLC_TTS_VOICE_TYPE=
VOLC_TTS_URL=

# ===== 火山引擎联网搜索 =====
TOOL_WEB_SEARCH_ACCESS_KEY=

# ===== 火山引擎 TOS（对象存储）=====
TOS_ACCESS_KEY_ID=
TOS_ACCESS_KEY_SECRET=
TOS_REGION=
TOS_ENDPOINT=
TOS_BUCKET=
TOS_ORIGIN_VIDEO_PREFIX=tos://your-bucket/input-video/
TOS_OUTPUT_VIDEO_PREFIX=tos://your-bucket/output-video/

{
  "name": "ai-glasses-agent-arkclaw",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @ai-glasses/glasses-web run dev",
    "dev:gateway": "npm --workspace @ai-glasses/gateway run dev",
